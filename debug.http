GET {{baseUrl}}/api/parts/33333333-3333-3333-3333-333333333333
### 期望: stockQuantity = 0 (初始5 - 消耗5)

GET {{baseUrl}}/api/parts/44444444-4444-4444-4444-444444444444
### 期望: stockQuantity = 0 (初始20 - 消耗20)

GET {{baseUrl}}/api/parts/55555555-5555-5555-5555-555555555555
### 期望: stockQuantity = 440 (初始500 - 消耗60)

GET {{baseUrl}}/api/parts/66666666-6666-6666-6666-666666666666
